# ── LLM Configuration ────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Database ─────────────────────────────────────────────
# SQLite (default – no setup needed):
DATABASE_URL=sqlite:///multi_agent_app/db/sample.db
# MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/mydb
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# SQL Server:
# DATABASE_URL=mssql+pyodbc://user:password@server/db?driver=ODBC+Driver+17+for+SQL+Server

# ── Web Search ───────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Vector Store ─────────────────────────────────────────
VECTOR_STORE_DIR=multi_agent_app/db/vector_store

# ── Server ───────────────────────────────────────────────
PORT=8000
